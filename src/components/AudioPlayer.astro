---
export interface Props {
  audioUrl: string;
  date: string;
}

const { audioUrl, date } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '/';
const fullUrl = audioUrl.startsWith('/') ? baseUrl.replace(/\/$/, '') + audioUrl : audioUrl;
---

<div class="audio-player">
  <span class="audio-label">&#9654; 语音播客</span>
  <audio controls preload="metadata">
    <source src={fullUrl} type="audio/mpeg" />
    您的浏览器不支持音频播放。
  </audio>
  <span class="audio-date">{date}</span>
</div>
