---
export interface Props {
  index?: number;
  title: string;
  summary: string;
  sourceName: string;
  url: string;
  pubDate?: string;
}

const { index, title, summary, sourceName, url, pubDate } = Astro.props;
const hasUrl = url && url.length > 1 && url !== '#';
---

<article class="news-card">
  {index && <span class="index">{String(index).padStart(2, '0')}</span>}
  <h3>
    {hasUrl ? <a href={url} target="_blank" rel="noopener noreferrer">{title}</a> : title}
  </h3>
  <span class="source-name">{sourceName}</span>
  <p class="summary">{summary}</p>
</article>
