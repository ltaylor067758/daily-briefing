---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import AudioPlayer from '../components/AudioPlayer.astro';

const briefings = await getCollection('briefings');
const sorted = briefings.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latest = sorted[0];

let briefingContent: any = null;

if (latest) {
  const { date, title } = latest.data;
  const body = latest.body || '';

  // Parse sections from markdown body
  const sections: { label: string; type: string; items: { title: string; summary: string; url: string; sourceName: string }[] }[] = [];
  let currentLabel = '';
  let currentType = '';
  let currentItems: typeof sections[0]['items'] = [];
  let quoteText = '';
  let itemIndex = 0;

  const lines = body.split('\n');
  for (const line of lines) {
    // Section header
    if (line.match(/^##\s/)) {
      if (currentLabel && currentItems.length > 0) {
        sections.push({ label: currentLabel, type: currentType, items: [...currentItems] });
      }
      const rawLabel = line.replace(/^##\s*/, '').trim();
      // strip emoji
      currentLabel = rawLabel.replace(/[\u{1F000}-\u{1FFFF}\u{2600}-\u{27BF}\u{1F900}-\u{1F9FF}\u{200D}\u{FE0F}]/gu, '').replace(/^\s+/, '');
      if (rawLabel.includes('国内')) currentType = 'domestic';
      else if (rawLabel.includes('国际')) currentType = 'international';
      else if (rawLabel.includes('AI') || rawLabel.includes('科技')) currentType = 'ai';
      else currentType = 'default';
      currentItems = [];
      continue;
    }

    // News item: "1. **[title]** — ..." or "1. **title** — ..."
    const itemMatch = line.match(/^\d+\.\s*\*\*\[?(.+?)\]?\*\*\s*[—\-]\s*(.+)/);
    if (itemMatch) {
      const itemTitle = itemMatch[1].trim();
      const afterTitle = itemMatch[2];
      let summary = '';
      let url = '';

      // Extract link: [阅读原文](url) or 阅读原文url
      const linkMatch = afterTitle.match(/^(.*?)\[阅读原文\]\(([^)]+)\)/);
      if (linkMatch) {
        summary = linkMatch[1].replace(/\.{2,}$/, '').trim();
        url = linkMatch[2].trim();
      } else {
        // Try bare URL at end
        const bareMatch = afterTitle.match(/^(.*?)(https?:\/\/\S+)/);
        if (bareMatch) {
          summary = bareMatch[1].replace(/\.{2,}$/, '').trim();
          url = bareMatch[2].trim();
        } else {
          summary = afterTitle.trim();
        }
      }

      if (itemTitle && summary) {
        itemIndex++;
        currentItems.push({
          title: itemTitle,
          summary,
          url,
          sourceName: currentLabel,
        });
      }
      continue;
    }

    // Quote
    if (line.match(/^>\s*\*\*今日金句/)) {
      const qMatch = line.match(/>\s*\*\*今日金句\*\*[：:]\s*(.+)/);
      if (qMatch) quoteText = qMatch[1].trim();
      continue;
    }
  }

  // Don't forget the last section
  if (currentLabel && currentItems.length > 0) {
    sections.push({ label: currentLabel, type: currentType, items: [...currentItems] });
  }

  const audioFile = latest.data.audio || `/audio/${date}.mp3`;
  briefingContent = { date, title, sections, quote: quoteText, audioUrl: audioFile };
}

function formatDateChinese(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}
---

<Layout title={briefingContent?.title || '每日简报'}>
  {
    !briefingContent ? (
      <div class="empty-state">
        <div class="icon">&#9744;</div>
        <h2>暂无简报</h2>
        <p>运行 pipeline 后这里将自动展示最新内容</p>
      </div>
    ) : (
      <>
        <div class="date-badge">{formatDateChinese(briefingContent.date)} &middot; 晨间简报</div>
        <AudioPlayer audioUrl={briefingContent.audioUrl} date={briefingContent.date} />
        <div class="news-grid">
        {
          briefingContent.sections.map(section => (
            <section class="news-section">
              <h2 class="section-header" data-section={section.type}>{section.label}</h2>
              {section.items.map((item: any, i: number) => (
                <NewsCard
                  index={i + 1}
                  title={item.title}
                  summary={item.summary}
                  sourceName={''}
                  url={item.url}
                />
              ))}
            </section>
          ))
        }
        </div>
        {
          briefingContent.quote && (
            <div class="daily-quote">
              <strong>今日金句</strong>&nbsp;&nbsp;{briefingContent.quote}
            </div>
          )
        }
      </>
    )
  }
</Layout>
